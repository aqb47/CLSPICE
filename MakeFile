CC = gcc
CFLAGS = -std=c11 -Wall -Wextra -g
INCLUDES = -I. -Imatrix

SRCS = $(wildcard *.c) $(wildcard matrix/*.c)
TARGET = clspice

.PHONY: all clean run debug

all: $(TARGET)

$(TARGET): $(SRCS)
	$(CC) $(CFLAGS) $(INCLUDES) -o $@ $^

clean:
	@if exist "$(TARGET).exe" del /q "$(TARGET).exe"
	@if exist "$(TARGET)" del /q "$(TARGET)"

run: all
	./$(TARGET) netlist.sp

debug: CFLAGS += -O0 -ggdb
debug: clean all

